{
  "info": {
    "_postman_id": "finsight-ai-api-collection",
    "name": "FinSight AI API",
    "description": "Complete API endpoints for FinSight AI expense tracking application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Receipt Upload",
      "item": [
        {
          "name": "Upload Receipt Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "description": "Receipt image file (JPG, PNG, GIF, BMP)",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8000/api/upload-receipt",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "upload-receipt"]
            },
            "description": "Upload a receipt image and run full analysis. The endpoint will extract merchant, amount, and category information."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Expense Management",
      "item": [
        {
          "name": "Add Expense (Manual Entry)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/add-expense?date=2024-03-13&merchant=Starbucks&category=food&amount=6.50&description=Morning coffee",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "add-expense"],
              "query": [
                {
                  "key": "date",
                  "value": "2024-03-13",
                  "description": "Date in YYYY-MM-DD format (required)"
                },
                {
                  "key": "merchant",
                  "value": "Starbucks",
                  "description": "Vendor/store name (required)"
                },
                {
                  "key": "category",
                  "value": "food",
                  "description": "Expense category (required)"
                },
                {
                  "key": "amount",
                  "value": "6.50",
                  "description": "Amount in decimal format, must be > 0 (required)"
                },
                {
                  "key": "description",
                  "value": "Morning coffee",
                  "description": "Optional notes/description"
                }
              ]
            },
            "description": "Add a new expense via text input (manual entry)"
          },
          "response": []
        },
        {
          "name": "Get All Expenses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/expenses?days=30&category=food",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "expenses"],
              "query": [
                {
                  "key": "days",
                  "value": "30",
                  "description": "Number of days to retrieve (1-365, default: 30)"
                },
                {
                  "key": "category",
                  "value": "food",
                  "description": "Filter by category (optional)"
                }
              ]
            },
            "description": "Retrieve all expenses for a specified period with optional category filtering"
          },
          "response": []
        }
      ]
    },
