# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Database Configuration
